{
  "version": 1,
  "apps": {
    "sampler": {
      "name": "Sampler",
      "version": "0.1.0",
      "description": "Sample player with 16 pads, waveform editing, kit management",
      "repo": "https://github.com/CrossPad/crosspad-sampler.git",
      "component_path": "components/crosspad-sampler",
      "icon": "audio.png",
      "category": "music",
      "platforms": [
        "esp-idf",
        "arduino"
      ],
      "requires": {
        "crosspad-core": ">=0.3.0",
        "crosspad-gui": ">=0.2.0"
      }
    },
    "mixer": {
      "name": "Mixer",
      "version": "0.1.0",
      "description": "Audio mixer/router with VU meters, routing matrix, channel strips",
      "repo": "https://github.com/CrossPad/crosspad-mixer.git",
      "component_path": "components/crosspad-mixer",
      "icon": "mixer.png",
      "category": "audio",
      "platforms": [
        "pc"
      ],
      "requires": {
        "crosspad-core": ">=0.3.0",
        "crosspad-gui": ">=0.2.0"
      }
    },
    "synthesizer": {
      "name": "Synthesizer",
      "version": "0.1.0",
      "description": "Polyphonic synth with 3 oscillators, ADSR, filter, effects",
      "repo": "https://github.com/CrossPad/crosspad-synthesizer.git",
      "component_path": "components/crosspad-synthesizer",
      "icon": "synth.png",
      "category": "music",
      "platforms": [
        "arduino"
      ],
      "requires": {
        "crosspad-core": ">=0.3.0",
        "crosspad-gui": ">=0.2.0"
      }
    },
    "sequencer": {
      "name": "Sequencer",
      "version": "0.2.0",
      "description": "MIDI step sequencer with recording, playback, overdub",
      "repo": "https://github.com/CrossPad/crosspad-sequencer.git",
      "component_path": "components/crosspad-sequencer",
      "icon": "sequencer.png",
      "category": "music",
      "platforms": [
        "arduino"
      ],
      "requires": {
        "crosspad-core": ">=0.3.0",
        "crosspad-gui": ">=0.2.0"
      }
    }
  }
}
